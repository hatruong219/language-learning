NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_ID=

# AI provider (gemini | openai), mặc định dùng Gemini (free tier)
AI_PROVIDER=gemini

# OpenAI API — ưu tiên dùng cho tính năng chấm bài viết tự động
# Lấy API key tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Tuỳ chọn, mặc định: gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini API — fallback khi không có OPENAI_API_KEY
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=